function parseProposal(text) {
  // Try to split into labeled sections
  const sectionRegex = /\*\*([^*]+)\*\*[:\s]*([\s\S]*?)(?=\*\*|$)/g;
  const sections = [];
  let match;
  while ((match = sectionRegex.exec(text)) !== null) {
    sections.push({ title: match[1].trim(), body: match[2].trim() });
  }
  if (sections.length > 1) return { type: "sections", sections };
  return { type: "raw", text };
}

export default function App() {
  const [tagInput, setTagInput] = useState("");
  const [tags, setTags] = useState([]);
  const [context, setContext] = useState("");
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState(null);
  const [error, setError] = useState(null);
  const [copied, setCopied] = useState(false);
  const inputRef = useRef(null);

  function addTag(val) {
    const cleaned = val.trim().replace(/,+$/, "");
    if (!cleaned) return;
    // Support comma-separated
    const parts = cleaned.split(",").map(s => s.trim()).filter(Boolean);
    setTags(prev => {
      const existing = new Set(prev.map(t => t.toLowerCase()));
      const newOnes = parts.filter(p => !existing.has(p.toLowerCase()));
      return [...prev, ...newOnes];
    });
    setTagInput("");
  }

  function handleKeyDown(e) {
    if (e.key === "Enter" || e.key === ",") {
      e.preventDefault();
      addTag(tagInput);
    } else if (e.key === "Backspace" && !tagInput && tags.length > 0) {
      setTags(prev => prev.slice(0, -1));
    }
  }

  function removeTag(i) {
    setTags(prev => prev.filter((_, idx) => idx !== i));
  }

  async function generate() {
    if (tags.length === 0) return;
    setLoading(true);
    setError(null);
    setResult(null);

    const prompt = `You are an expert business proposal writer. A client has provided the following keywords as the skeleton/foundation of their business idea:

Keywords: ${tags.join(", ")}
${context ? `\nAdditional context: ${context}` : ""}

Using these keywords as the structural backbone, write a compelling, professional business proposal. Structure it with these clearly labeled sections (use **Section Title** format):

**Executive Summary**
**The Problem**
**Our Solution**
**Value Proposition**
**Target Market**
**Business Model**
**Why Us**
**Call to Action**

Each section should be 2-4 sentences. Weave the provided keywords naturally and prominently throughout. Be concise, persuasive, and professional. Do not add any preamble or closing remarks outside the sections.`;

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{ role: "user", content: prompt }],
        }),
      });
      const data = await response.json();
      const text = data.content?.map(b => b.text || "").join("\n") || "";
      if (!text) throw new Error("Empty response from API");
      setResult(text);
    } catch (err) {
      setError(err.message || "Something went wrong. Please try again.");
    } finally {
      setLoading(false);
    }
  }

  function copyToClipboard() {
    if (!result) return;
    navigator.clipboard.writeText(result).then(() => {
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    });
  }

  const parsed = result ? parseProposal(result) : null;

  return (
    <div style={styles.root}>
      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        button:hover { opacity: 0.85; }
        textarea:focus, input:focus { border-color: #C8F04A44 !important; }
        ::-webkit-scrollbar { width: 6px; } 
        ::-webkit-scrollbar-track { background: #111; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
      `}</style>

      <header style={styles.header}>
        <div style={styles.logoBlock}>
          <span style={styles.logoTag}>AI-Powered</span>
          <span style={styles.logoTitle}>PitchForge</span>
          <span style={styles.subTitle}>Turn keywords into compelling business proposals</span>
        </div>
        <div style={{ fontSize: 12, color: "#444", fontFamily: "'Courier New', monospace", textAlign: "right" }}>
          {tags.length > 0 && <span style={{ color: ACCENT }}>{tags.length} keyword{tags.length !== 1 ? "s" : ""} loaded</span>}
        </div>
      </header>

      <main style={styles.main}>
        {/* Keywords Input */}
        <div style={styles.sectionLabel}>Step 1 — Keywords</div>
        <div style={styles.h2}>Enter your keywords</div>
        <p style={{ color: MUTED, fontSize: 14, marginBottom: 16, lineHeight: 1.6 }}>
          Type keywords one by one (press <kbd style={{ background: "#222", border: "1px solid #333", borderRadius: 4, padding: "1px 6px", fontSize: 12 }}>Enter</kbd>) or paste them comma-separated.
        </p>

        <div style={styles.inputRow}>
          <input
            ref={inputRef}
            style={styles.input}
            value={tagInput}
            onChange={e => setTagInput(e.target.value)}
            onKeyDown={handleKeyDown}
            placeholder="e.g. sustainability, SaaS, enterprise, AI-driven..."
          />
          <button style={styles.addBtn} onClick={() => addTag(tagInput)}>+ Add</button>
        </div>

        {tags.length > 0 && (
          <div style={styles.tagsWrap}>
            {tags.map((tag, i) => (
              <span key={i} style={styles.tag}>
                {tag}
                <button style={styles.tagX} onClick={() => removeTag(i)}>×</button>
              </span>
            ))}
          </div>
        )}

        <hr style={styles.divider} />

        {/* Context Input */}
        <div style={styles.sectionLabel}>Step 2 — Context (optional)</div>
        <div style={styles.h2}>Add any extra details</div>
        <textarea
          style={styles.contextInput}
          value={context}
          onChange={e => setContext(e.target.value)}
          placeholder="e.g. This is for a B2B startup targeting healthcare providers in Southeast Asia..."
          rows={3}
        />

        {/* Generate */}
        <button
          style={{
            ...styles.generateBtn,
            opacity: tags.length === 0 || loading ? 0.4 : 1,
            cursor: tags.length === 0 || loading ? "not-allowed" : "pointer",
          }}
          onClick={generate}
          disabled={tags.length === 0 || loading}
        >
          {loading ? "GENERATING..." : "→ GENERATE PROPOSAL"}
        </button>

        {/* Error */}
        {error && <div style={styles.errorBox}>⚠ {error}</div>}

        {/* Loading */}
        {loading && (
          <div style={styles.loadingWrap}>
            <div style={styles.spinner} />
            <span style={styles.loadingText}>Crafting your proposal from {tags.length} keywords...</span>
          </div>
        )}

        {/* Result */}
        {parsed && (
          <div style={styles.resultCard}>
            <div style={styles.resultHeader}>
              <span style={{ ...styles.sectionLabel, marginBottom: 0 }}>Generated Proposal</span>
              <button style={styles.copyBtn} onClick={copyToClipboard}>
                {copied ? "✓ Copied" : "Copy text"}
              </button>
            </div>

            {parsed.type === "sections"
              ? parsed.sections.map((s, i) => (
                  <div key={i} style={styles.proposalSection}>
                    <h3 style={styles.proposalH3}>{s.title}</h3>
                    <p style={styles.proposalP}>{s.body}</p>
                  </div>
                ))
              : <p style={styles.proposalP}>{parsed.text}</p>
            }

            <div style={styles.keywordsUsed}>
              {tags.map((t, i) => (
                <span key={i} style={styles.kwChip}>#{t}</span>
              ))}
            </div>
          </div>
        )}
      </main>
    </div>
  );
}
